{
	"name": "@redwood-labs/scanner",
	"version": "0.2.0",
	"description": "Security scanner for AI-native codebases",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"redwood": "./dist/cli.js",
		"redwood-scan": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup src/cli.ts src/index.ts src/ansi.ts --format esm --clean",
		"dev": "tsup src/cli.ts src/index.ts src/ansi.ts --format esm --watch",
		"test": "tsx --test",
		"lint": "tsc --noEmit && npx @biomejs/biome check --write .",
		"format": "npx @biomejs/biome format --write .",
		"format:check": "npx @biomejs/biome format .",
		"biome:check": "npx @biomejs/biome check .",
		"biome:fix": "npx @biomejs/biome check --write .",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"security",
		"scanner",
		"sast",
		"mcp",
		"ai",
		"agent",
		"code-review",
		"vulnerability"
	],
	"author": "Redwood Labs",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/redwood-labs-ai/scanner"
	},
	"bugs": {
		"url": "https://github.com/redwood-labs-ai/scanner/issues"
	},
	"homepage": "https://redwoodlabs.ai",
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"commander": "^12.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/node": "^20.11.0",
		"tsup": "^8.0.1",
		"tsx": "^4.21.0",
		"typescript": "^5.3.3"
	}
}
